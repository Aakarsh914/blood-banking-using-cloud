PORT=5000
# Default SQLite (no external DB needed):
DATABASE_URL=sqlite:./data/bloodbank.db
# Local Postgres:
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/bloodbank
# Supabase Postgres (Transaction pooler):
# DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
JWT_SECRET=change_this_secret
AWS_REGION=ap-south-1
S3_BUCKET_NAME=your-blood-bank-bucket
SNS_TOPIC_ARN=arn:aws:sns:ap-south-1:123456789012:low-stock-alerts
FRONTEND_ORIGIN=http://localhost:5173
