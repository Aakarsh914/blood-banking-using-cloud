# Supabase Postgres (Settings → Database → pooler URI, port 6543)
DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true

# Auth
JWT_SECRET=generate_a_long_random_string

# Gmail SMTP (free) — App Password, not your normal Gmail password
SMTP_USER=your.email@gmail.com
SMTP_PASS=your_16_char_app_password

# After first deploy, set to your Vercel URL
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# Supabase Realtime (optional, for SOS toast alerts)
NEXT_PUBLIC_SUPABASE_URL=https://[PROJECT_REF].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
